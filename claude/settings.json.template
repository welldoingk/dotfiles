{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "default"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{HOME_DIR}}/.claude/hooks/post-work-gate.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); dir=$(echo \"$input\" | jq -r '.workspace.current_dir'); git_branch=$(cd \"$dir\" 2>/dev/null && git branch --show-current 2>/dev/null || echo ''); git_status=$(cd \"$dir\" 2>/dev/null && git diff --quiet 2>/dev/null && git diff --cached --quiet 2>/dev/null && echo '' || echo '*'); user=$(whoami); host=$(hostname -s); if [ -n \"$git_branch\" ]; then printf \"\\033[01;32m%s@%s\\033[00m:\\033[01;34m%s\\033[00m \\033[33m(%s%s)\\033[00m\" \"$user\" \"$host\" \"$dir\" \"$git_branch\" \"$git_status\"; else printf \"\\033[01;32m%s@%s\\033[00m:\\033[01;34m%s\\033[00m\" \"$user\" \"$host\" \"$dir\"; fi"
  },
  "language": "한글",
  "skipDangerousModePermissionPrompt": true,
  "enabledPlugins": {
    "context-mode@claude-context-mode": true
  }
}
